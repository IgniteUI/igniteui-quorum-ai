{
  "_comment": "1. Paste the 'mcpServers' block into claude_desktop_config.json.  2. Stop MAKER.McpServer if it is already running — Claude Desktop will own the process via STDIO.",
  "_configLocation": {
    "windows": "%APPDATA%\\Claude\\claude_desktop_config.json",
    "macOS":   "~/Library/Application Support/Claude/claude_desktop_config.json"
  },
  "mcpServers": {
    "maker": {
      "command": "npx",
      "args": ["-y", "@igniteui/maker-mcp", "--stdio"],
      "env": {
        "Executor__AIProviderKeys__OpenAI":    "<your-openai-key>",
        "Executor__AIProviderKeys__Anthropic": "<your-anthropic-key>",
        "Executor__AIProviderKeys__Google":    "<your-google-key>"
      }
    }
  }
}
