{
  "_comment": "1. Paste the 'mcpServers' block into claude_desktop_config.json.  2. Update the project path to match your local setup.  3. Stop MAKER.McpServer if it is already running — Claude Desktop will own the process via STDIO.",
  "_configLocation": {
    "windows": "%APPDATA%\\Claude\\claude_desktop_config.json",
    "macOS":   "~/Library/Application Support/Claude/claude_desktop_config.json"
  },
  "mcpServers": {
    "maker": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "<path-to-MAKER.McpServer.csproj>",
        "--",
        "--stdio"
      ],
      "env": {
        "Executor__AIProviderKeys__OpenAI":             "<your-openai-key>",
        "Executor__AIProviderKeys__Anthropic":          "<your-anthropic-key>",
        "Executor__AIProviderKeys__Google":             "<your-google-key>",
        "Executor__Format":                             "plaintext",
        "Executor__Clients__Planning__Provider":        "OpenAI",
        "Executor__Clients__Planning__Model":           "gpt-5.1",
        "Executor__Clients__PlanVoting__Provider":      "OpenAI",
        "Executor__Clients__PlanVoting__Model":         "gpt-5.1",
        "Executor__Clients__Execution__Provider":       "OpenAI",
        "Executor__Clients__Execution__Model":          "gpt-5.1",
        "Executor__Clients__ExecutionVoting__Provider": "OpenAI",
        "Executor__Clients__ExecutionVoting__Model":    "gpt-5.1"
      }
    }
  }
}
